# MoeFit Command Center - environment variables
#
# The app works fully WITHOUT any of these (pure localStorage + a built-in
# rule-based coach). Add the cloud vars below to sync across devices via Neon.

# ---- Cloud sync (Neon Postgres + passcode) ----
# Turn cloud sync ON. When "true", the app shows a passcode screen and syncs to
# Neon, using localStorage as an offline cache. Leave unset for local-only mode.
NEXT_PUBLIC_CLOUD_ENABLED=

# Neon connection string. On Vercel, add the Neon integration and this is set
# for you automatically. Locally, copy it from the Neon dashboard.
DATABASE_URL=

# The single shared passcode that unlocks the app (pick something strong).
# Not needed if you use Google sign-in below.
APP_PASSCODE=

# ---- Google sign-in (optional, alternative to the passcode) ----
# Set to "true" to gate the app behind Google sign-in instead of a passcode.
# Requires NEXT_PUBLIC_CLOUD_ENABLED=true + DATABASE_URL. Each Google account
# gets its own data, synced across every device you sign in on.
NEXT_PUBLIC_GOOGLE_AUTH=
# From Google Cloud Console → APIs & Services → Credentials → OAuth client ID
# (type: Web application). Authorized redirect URI:
#   https://YOUR-DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Random secret for session signing — generate with: openssl rand -base64 32
AUTH_SECRET=

# ---- AI Coach (optional, recommended) ----
# Add an Anthropic API key to turn the chatbot into a real Claude-powered coach.
# Without it, the app uses a built-in offline coach (still works, just simpler).
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: override the model. Defaults to claude-opus-4-7 (most capable).
# For faster/cheaper replies, set to claude-haiku-4-5.
AI_MODEL=
