# MoeFit Command Center - environment variables
#
# The app works fully WITHOUT any of these (it uses local storage + a built-in
# rule-based coach). Fill these in later when you want to connect a real AI API
# or a cloud database. See lib/coach.ts and lib/store.tsx for the integration
# points marked with "INTEGRATION POINT".

# ---- AI Coach (optional) ----
# Add an OpenAI / Anthropic style key here and wire it up in lib/coach.ts
NEXT_PUBLIC_AI_PROVIDER=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Supabase (optional, for cloud sync later) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Firebase (optional alternative) ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
